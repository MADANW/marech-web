# Copy to .env.local for local dev, or set these in the Vercel dashboard.

# Connect to the real backend API. Set to "false" to use live data;
# leave unset (or any other value) to run the UI against mock data.
NEXT_PUBLIC_MOCK=false

# Base URL of the block.me backend API (on AWS).
# Local dev:   http://localhost:3000   (run the API on 3000, web on 3001 via `npm run dev:demo`)
# Production:  https://api.block.me
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: separate host that serves the protection snippet (/cdn/:id.js).
# Defaults to NEXT_PUBLIC_API_URL when unset.
# NEXT_PUBLIC_CDN_URL=https://api.block.me

# Google sign-in. OAuth 2.0 Web client ID from Google Cloud Console.
# Must be the SAME client id configured as GOOGLE_CLIENT_ID on the backend.
# Leave blank to hide the real Google button (a mock fallback shows in mock mode).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
